<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Manual Comercial PLURI v1.1</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">

    <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.min.js">
    </script>

    <style>
        :root {
            --navy: #002C47;
            --navy-light: #003d61;
            --navy-dark: #001a2b;
            --yellow: #FFBE46;
            --yellow-light: #FFD580;
            --yellow-dark: #e6a800;
            --white: #FFFFFF;
            --bg: #F3F4F6;
            --bg-secondary: #F9FAFB;
            --card-bg: #FFFFFF;
            --text: #111827;
            --text-secondary: #4B5563;
            --text-tertiary: #9CA3AF;
            --border: #E5E7EB;
            --border-light: #F3F4F6;
            --success: #10B981;
            --success-bg: #ECFDF5;
            --danger: #EF4444;
            --danger-bg: #FEF2F2;
            --warning: #F59E0B;
            --info: #3B82F6;
            --info-bg: #EFF6FF;
            --shadow-xs: 0 1px 2px rgba(0, 0, 0, 0.04);
            --shadow-sm: 0 1px 3px rgba(0, 0, 0, 0.06), 0 1px 2px rgba(0, 0, 0, 0.04);
            --shadow-md: 0 4px 6px rgba(0, 0, 0, 0.05), 0 2px 4px rgba(0, 0, 0, 0.04);
            --shadow-lg: 0 10px 25px rgba(0, 0, 0, 0.08), 0 4px 10px rgba(0, 0, 0, 0.04);
            --shadow-xl: 0 20px 40px rgba(0, 0, 0, 0.1), 0 8px 16px rgba(0, 0, 0, 0.05);
            --shadow-glow-yellow: 0 0 0 4px rgba(255, 190, 70, 0.25);
            --radius-sm: 8px;
            --radius: 12px;
            --radius-lg: 16px;
            --radius-xl: 20px;
            --sidebar-width: 268px;
            --header-height: 82px;
            --progress-height: 4px;
            --transition-fast: 150ms cubic-bezier(0.4, 0, 0.2, 1);
            --transition: 250ms cubic-bezier(0.4, 0, 0.2, 1);
            --transition-slow: 400ms cubic-bezier(0.4, 0, 0.2, 1);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        html {
            scroll-behavior: smooth;
            scroll-padding-top: calc(var(--header-height) + 16px);
        }

        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            background-color: var(--bg);
            color: var(--text);
            line-height: 1.6;
            -webkit-font-smoothing: antialiased;
            -moz-osx-font-smoothing: grayscale;
            min-height: 100vh;
            padding-top: var(--header-height);
        }

        /* ============ PROGRESS BAR ============ */
        .progress-bar {
            position: fixed;
            top: var(--header-height);
            left: 0;
            height: var(--progress-height);
            background: linear-gradient(90deg, var(--yellow), #f59e0b);
            z-index: 149;
            width: 0%;
            transition: width 0.1s linear;
            border-radius: 0 2px 2px 0;
            box-shadow: 0 0 8px rgba(255, 190, 70, 0.5);
        }

        /* ============ HEADER FIXO ============ */
        .app-header {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            height: var(--header-height);
            background: rgba(0, 44, 71, 0.95);
            backdrop-filter: blur(12px);
            color: #fff;
            z-index: 150;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 24px;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.35);
            border-bottom: 1px solid rgba(255, 255, 255, 0.04);
            gap: 16px;
            flex-shrink: 0;
            transition: 0.3s ease;
        }
        .app-header.scrolled {
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.5);
        }
        .header-brand {
            display: flex;
            align-items: center;
            gap: 14px;
            min-width: 0;
        }
        .header-logo-icon {
            width: 52px;
            height: 52px;
            flex-shrink: 0;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .header-logo-icon img {
            width: 100%;
            height: 100%;
            object-fit: contain;
            display: block;
        }
        .header-brand-text {
            display: flex;
            flex-direction: column;
            line-height: 1.2;
        }
        .header-brand-text .brand-name {
            font-weight: 700;
            font-size: 1rem;
            letter-spacing: 0.2em;
            color: #fff;
        }
        .header-brand-text .brand-sub {
            font-size: 0.68rem;
            font-weight: 400;
            opacity: 0.7;
            letter-spacing: 0.14em;
            margin-top: 3px;
            text-transform: uppercase;
        }
        .header-whatsapp {
            display: flex;
            align-items: center;
            gap: 8px;
            background: #25D366;
            color: #fff;
            text-decoration: none;
            padding: 12px 22px;
            border-radius: 999px;
            font-weight: 700;
            font-size: 0.9rem;
            letter-spacing: -0.1px;
            transition: all var(--transition-fast);
            white-space: nowrap;
            flex-shrink: 0;
            box-shadow: 0 12px 35px rgba(37, 211, 102, 0.25);
        }
        .header-whatsapp:hover {
            background: #20bd5a;
            transform: translateY(-2px);
            box-shadow: 0 16px 40px rgba(37, 211, 102, 0.35);
        }
        .header-whatsapp i {
            width: 18px;
            height: 18px;
        }
        .header-whatsapp span {
            display: inline;
        }
        @media (max-width: 500px) {
            .header-whatsapp span {
                display: none;
            }
            .header-whatsapp {
                padding: 12px 16px;
            }
            .app-header {
                padding: 0 12px;
            }
        }

        /* ============ FLOATING WHATSAPP BUTTON ============ */
        .floating-whatsapp {
            position: fixed;
            bottom: 28px;
            right: 28px;
            z-index: 130;
            width: 60px;
            height: 60px;
            background: #25D366;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 8px 30px rgba(37, 211, 102, 0.4);
            transition: all var(--transition);
            cursor: pointer;
            text-decoration: none;
            animation: float 3s ease-in-out infinite;
        }
        .floating-whatsapp:hover {
            transform: scale(1.08);
            box-shadow: 0 12px 40px rgba(37, 211, 102, 0.55);
            animation: none;
        }
        .floating-whatsapp i {
            width: 28px;
            height: 28px;
            color: #fff;
        }
        .floating-whatsapp .tooltip {
            position: absolute;
            right: 70px;
            background: #1F2937;
            color: #fff;
            padding: 8px 16px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 600;
            white-space: nowrap;
            opacity: 0;
            pointer-events: none;
            transition: opacity var(--transition);
        }
        .floating-whatsapp:hover .tooltip {
            opacity: 1;
        }
        @keyframes float {
            0%,
            100% {
                transform: translateY(0);
            }
            50% {
                transform: translateY(-8px);
            }
        }
        @media (max-width: 768px) {
            .floating-whatsapp {
                bottom: 20px;
                right: 16px;
                width: 52px;
                height: 52px;
            }
            .floating-whatsapp i {
                width: 24px;
                height: 24px;
            }
            .floating-whatsapp .tooltip {
                display: none;
            }
        }

        /* ============ APP LAYOUT ============ */
        .app-container {
            display: flex;
            min-height: calc(100vh - var(--header-height));
            position: relative;
        }

        /* ============ SIDEBAR OVERLAY (MOBILE) ============ */
        .sidebar-overlay {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(0, 0, 0, 0.5);
            z-index: 90;
            opacity: 0;
            transition: opacity var(--transition);
            pointer-events: none;
        }
        .sidebar-overlay.active {
            opacity: 1;
            pointer-events: auto;
        }

        /* ============ SIDEBAR ============ */
        .sidebar {
            position: fixed;
            top: var(--header-height);
            left: 0;
            width: var(--sidebar-width);
            height: calc(100vh - var(--header-height));
            background: var(--navy);
            color: var(--white);
            z-index: 100;
            display: flex;
            flex-direction: column;
            overflow-y: auto;
            overflow-x: hidden;
            transition: transform var(--transition-slow);
            box-shadow: 4px 0 20px rgba(0, 0, 0, 0.15);
            flex-shrink: 0;
        }

        .sidebar-nav {
            flex: 1;
            padding: 12px 10px;
            display: flex;
            flex-direction: column;
            gap: 2px;
            margin-top: 4px;
        }
        .sidebar-nav a {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 10px 14px;
            border-radius: var(--radius-sm);
            color: rgba(255, 255, 255, 0.75);
            text-decoration: none;
            font-size: 13.5px;
            font-weight: 500;
            transition: all var(--transition-fast);
            white-space: nowrap;
            letter-spacing: -0.1px;
            position: relative;
        }
        .sidebar-nav a:hover {
            background: rgba(255, 255, 255, 0.08);
            color: #fff;
        }
        .sidebar-nav a.active {
            background: rgba(255, 190, 70, 0.15);
            color: var(--yellow);
            font-weight: 600;
        }
        .sidebar-nav a.active::before {
            content: '';
            position: absolute;
            left: 0;
            top: 8px;
            bottom: 8px;
            width: 3px;
            background: var(--yellow);
            border-radius: 0 4px 4px 0;
        }
        .sidebar-nav a i {
            width: 18px;
            height: 18px;
            flex-shrink: 0;
            opacity: 0.85;
        }
        .sidebar-nav a.active i {
            opacity: 1;
            color: var(--yellow);
        }
        .sidebar-footer {
            padding: 16px 20px;
            border-top: 1px solid rgba(255, 255, 255, 0.12);
            font-size: 11px;
            opacity: 0.55;
            text-align: center;
            flex-shrink: 0;
            letter-spacing: 0.2px;
        }

        /* ============ MAIN CONTENT ============ */
        .main-content {
            flex: 1;
            margin-left: var(--sidebar-width);
            padding: 28px 32px 40px;
            max-width: 1100px;
            width: 100%;
            transition: margin-left var(--transition-slow);
        }

        /* ============ MOBILE MENU TOGGLE ============ */
        .menu-toggle {
            display: none;
            position: fixed;
            top: calc(var(--header-height) + 12px);
            left: 16px;
            z-index: 110;
            width: 42px;
            height: 42px;
            border-radius: 50%;
            background: var(--navy);
            color: #fff;
            border: none;
            cursor: pointer;
            align-items: center;
            justify-content: center;
            box-shadow: var(--shadow-lg);
            transition: all var(--transition-fast);
        }
        .menu-toggle:hover {
            background: var(--navy-light);
            transform: scale(1.04);
        }
        .menu-toggle:active {
            transform: scale(0.96);
        }

        /* ============ SCROLL REVEAL ============ */
        .reveal {
            opacity: 0;
            transform: translateY(24px);
            transition: opacity 0.6s ease, transform 0.6s ease;
        }
        .reveal.visible {
            opacity: 1;
            transform: translateY(0);
        }

        /* ============ SECTION STYLES ============ */
        .section {
            margin-bottom: 40px;
            scroll-margin-top: calc(var(--header-height) + 16px);
        }
        .section-header {
            margin-bottom: 20px;
        }
        .section-header h2 {
            font-size: 22px;
            font-weight: 700;
            color: var(--navy);
            letter-spacing: -0.3px;
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .section-header h2 i {
            color: var(--yellow);
            width: 26px;
            height: 26px;
        }
        .section-header p {
            color: var(--text-secondary);
            font-size: 14px;
            margin-top: 4px;
            font-weight: 400;
        }

        /* ============ TWO-COLUMN LAYOUT ============ */
        .two-col-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 24px;
            align-items: start;
        }
        .two-col-grid .section {
            margin-bottom: 0;
        }

        /* ============ CARD BASE ============ */
        .card {
            background: var(--card-bg);
            border-radius: var(--radius-lg);
            padding: 20px 24px;
            box-shadow: var(--shadow-sm);
            border: 1px solid var(--border-light);
            transition: all var(--transition);
            position: relative;
            overflow: hidden;
        }
        .card:hover {
            box-shadow: var(--shadow-md);
            transform: translateY(-1px);
        }
        .card-accent {
            border-left: 4px solid var(--yellow);
        }
        .card-glow {
            box-shadow: var(--shadow-md);
        }
        .card-glow:hover {
            box-shadow: var(--shadow-lg), var(--shadow-glow-yellow);
        }
        .card-blue {
            background: linear-gradient(135deg, #F0F7FF 0%, #FAFCFF 100%);
            border: 1.5px solid #BFDBFE;
        }
        .card-red {
            background: #FFF5F5;
            border: 1px solid #FECACA;
        }
        .card-green {
            background: #F0FDF4;
            border: 1px solid #86EFAC;
        }
        .card-yellow {
            background: linear-gradient(135deg, #FFFDF5, #FFFBEB);
            border: 2px solid var(--yellow);
            box-shadow: var(--shadow-md);
        }
        .card-gray {
            background: #F9FAFB;
            border: 1px solid #E5E7EB;
        }

        /* ============ HERO ============ */
        .hero-section {
            margin-bottom: 36px;
            margin-top: 8px;
        }
        .hero-badge {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            background: var(--info-bg);
            color: var(--info);
            font-size: 12px;
            font-weight: 600;
            padding: 6px 14px;
            border-radius: 20px;
            letter-spacing: 0.2px;
            margin-bottom: 16px;
            text-transform: uppercase;
        }
        .hero-title {
            font-size: 36px;
            font-weight: 800;
            color: var(--navy);
            letter-spacing: -1px;
            line-height: 1.15;
            margin-bottom: 8px;
        }
        .hero-subtitle {
            font-size: 16px;
            color: var(--text-secondary);
            font-weight: 400;
            margin-bottom: 20px;
            line-height: 1.5;
        }
        .hero-highlight-card {
            background: linear-gradient(135deg, #fffdf7 0%, #fff 100%);
            border: 1.5px solid var(--yellow);
            border-radius: var(--radius-lg);
            padding: 18px 22px;
            font-size: 14.5px;
            color: var(--navy);
            font-weight: 500;
            line-height: 1.6;
            box-shadow: var(--shadow-sm);
            position: relative;
        }
        .hero-highlight-card::before {
            content: '';
            position: absolute;
            top: -1px;
            left: 20px;
            right: 20px;
            height: 3px;
            background: var(--yellow);
            border-radius: 0 0 6px 6px;
        }
        .hero-highlight-card strong {
            color: var(--navy);
            font-weight: 700;
        }

        /* ============ MISSION / VISION / VALUES CARDS ============ */
        .mvv-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 16px;
            margin-top: 20px;
        }
        .mvv-card {
            background: var(--card-bg);
            border-radius: var(--radius-lg);
            padding: 22px 20px;
            border: 1px solid var(--border-light);
            box-shadow: var(--shadow-sm);
            transition: all var(--transition);
            text-align: center;
        }
        .mvv-card:hover {
            box-shadow: var(--shadow-md);
            transform: translateY(-2px);
            border-color: var(--yellow);
        }
        .mvv-card i {
            width: 32px;
            height: 32px;
            color: var(--yellow);
            margin-bottom: 10px;
        }
        .mvv-card h3 {
            font-size: 16px;
            font-weight: 700;
            color: var(--navy);
            margin-bottom: 8px;
        }
        .mvv-card p,
        .mvv-card ul {
            font-size: 13.5px;
            color: var(--text-secondary);
            line-height: 1.6;
            list-style: none;
            padding: 0;
        }
        .mvv-card ul li {
            padding: 2px 0;
        }

        /* ============ SELL / DONT SELL ============ */
        .sell-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 16px;
            margin-bottom: 16px;
        }
        .sell-column {
            display: flex;
            flex-direction: column;
            gap: 8px;
        }
        .sell-column h3 {
            font-size: 14px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 6px;
            display: flex;
            align-items: center;
            gap: 6px;
        }
        .sell-column.dont h3 {
            color: #DC2626;
        }
        .sell-column.do h3 {
            color: #059669;
        }
        .sell-item {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 11px 14px;
            border-radius: var(--radius-sm);
            font-size: 13.5px;
            font-weight: 500;
            transition: all var(--transition-fast);
            background: var(--bg-secondary);
            border: 1px solid transparent;
        }
        .sell-column.dont .sell-item {
            background: #FEF2F2;
            color: #991B1B;
            border-color: #FECACA;
        }
        .sell-column.do .sell-item {
            background: #ECFDF5;
            color: #065F46;
            border-color: #A7F3D0;
        }
        .sell-item i {
            width: 18px;
            height: 18px;
            flex-shrink: 0;
        }
        .sell-conclusion {
            text-align: center;
            font-weight: 600;
            font-size: 15px;
            color: var(--navy);
            padding: 14px 20px;
            background: #FFFDF5;
            border-radius: var(--radius);
            border: 1px dashed var(--yellow);
            letter-spacing: -0.2px;
        }

        /* ============ BENEFITS GRID ============ */
        .benefits-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
            gap: 10px;
            margin-bottom: 20px;
        }
        .benefit-card {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 14px 16px;
            background: var(--card-bg);
            border-radius: var(--radius);
            border: 1px solid var(--border-light);
            font-size: 13.5px;
            font-weight: 500;
            color: var(--text);
            transition: all var(--transition-fast);
            box-shadow: var(--shadow-xs);
            cursor: default;
        }
        .benefit-card:hover {
            border-color: var(--yellow);
            box-shadow: var(--shadow-md);
            transform: translateY(-2px);
            background: #FFFEFA;
        }
        .benefit-card i {
            width: 20px;
            height: 20px;
            color: var(--navy);
            flex-shrink: 0;
            opacity: 0.7;
        }

        /* ============ EXAMPLE CARD ============ */
        .example-card {
            background: linear-gradient(135deg, #F0FDF4 0%, #FAFFF5 100%);
            border: 1.5px solid #86EFAC;
            border-radius: var(--radius-lg);
            padding: 22px 26px;
            margin-bottom: 20px;
            box-shadow: var(--shadow-sm);
        }
        .example-card h3 {
            font-weight: 700;
            color: var(--navy);
            margin-bottom: 12px;
            font-size: 16px;
            display: flex;
            align-items: center;
            gap: 8px;
        }
        .scenario {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 16px;
            margin: 12px 0;
        }
        .scenario-block {
            padding: 14px;
            border-radius: var(--radius-sm);
            font-size: 13.5px;
            font-weight: 500;
            line-height: 1.6;
        }
        .scenario-block.without {
            background: #FFF5F5;
            border: 1px solid #FECACA;
            color: #991B1B;
        }
        .scenario-block.with {
            background: #F0FDF4;
            border: 1px solid #86EFAC;
            color: #065F46;
        }
        .example-result {
            font-weight: 600;
            font-size: 14px;
            color: var(--navy);
            margin-top: 10px;
            text-align: center;
            padding: 10px;
            background: #FFFDF5;
            border-radius: var(--radius-sm);
            border: 1px dashed var(--yellow);
        }

        /* ============ EXPLAIN BOX ============ */
        .explain-box {
            background: linear-gradient(135deg, #F0F7FF 0%, #FAFCFF 100%);
            border: 1.5px solid #BFDBFE;
            border-radius: var(--radius-lg);
            padding: 22px 26px;
            font-size: 15px;
            color: var(--navy);
            line-height: 1.7;
            box-shadow: var(--shadow-sm);
            position: relative;
        }
        .explain-box .highlight-quote {
            display: block;
            margin-top: 14px;
            font-weight: 600;
            color: #1E40AF;
            font-size: 14.5px;
            padding-top: 12px;
            border-top: 1px solid #BFDBFE;
            letter-spacing: -0.2px;
        }

        /* ============ GOLDEN RULE CARD ============ */
        .golden-rule-card {
            background: linear-gradient(135deg, #FFFDF5 0%, #FFFBEB 100%);
            border: 2px solid var(--yellow);
            border-radius: var(--radius-lg);
            padding: 24px 28px;
            box-shadow: var(--shadow-md);
        }
        .golden-rule-card h3 {
            font-size: 18px;
            font-weight: 700;
            color: var(--navy);
            margin-bottom: 12px;
            display: flex;
            align-items: center;
            gap: 8px;
        }
        .golden-rule-card ul {
            list-style: none;
            padding: 0;
            margin: 12px 0;
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 6px;
        }
        .golden-rule-card ul li {
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 13.5px;
            font-weight: 500;
            color: var(--navy);
            padding: 8px 0;
            border-bottom: 1px solid #FFF0C4;
        }
        .golden-rule-card ul li i {
            color: var(--yellow-dark);
            width: 16px;
            height: 16px;
            flex-shrink: 0;
        }

        /* ============ AUDIENCE GRID ============ */
        .audience-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
            gap: 10px;
            margin-bottom: 16px;
        }
        .audience-card {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 14px 16px;
            background: var(--card-bg);
            border-radius: var(--radius);
            border: 1px solid var(--border-light);
            font-size: 13.5px;
            font-weight: 500;
            color: var(--text);
            transition: all var(--transition-fast);
            cursor: default;
            box-shadow: var(--shadow-xs);
        }
        .audience-card:hover {
            border-color: var(--yellow);
            box-shadow: var(--shadow-md);
            transform: translateY(-2px);
            background: #FFFEFA;
        }
        .audience-card i {
            width: 20px;
            height: 20px;
            color: var(--navy);
            flex-shrink: 0;
            opacity: 0.7;
        }
        .avoid-block {
            background: #F9FAFB;
            border: 1px solid #E5E7EB;
            border-radius: var(--radius);
            padding: 16px 20px;
            font-size: 13.5px;
            color: var(--text-secondary);
        }
        .avoid-block strong {
            color: var(--text);
            display: flex;
            align-items: center;
            gap: 6px;
            margin-bottom: 6px;
            font-size: 14px;
        }
        .avoid-block ul {
            list-style: none;
            padding: 0;
            display: flex;
            flex-direction: column;
            gap: 4px;
        }
        .avoid-block ul li::before {
            content: '•';
            color: #9CA3AF;
            margin-right: 8px;
            font-weight: bold;
        }

        /* ============ CHECKLIST ============ */
        .checklist {
            display: flex;
            flex-direction: column;
            gap: 6px;
        }
        .checklist-item {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 13px 16px;
            background: var(--card-bg);
            border-radius: var(--radius-sm);
            border: 1px solid var(--border-light);
            cursor: pointer;
            transition: all var(--transition-fast);
            font-size: 14px;
            font-weight: 500;
            user-select: none;
            -webkit-tap-highlight-color: transparent;
        }
        .checklist-item:hover {
            border-color: #D1D5DB;
            background: #FAFBFC;
        }
        .checklist-item.checked {
            background: #F0FDF4;
            border-color: #86EFAC;
        }
        .checklist-checkbox {
            width: 22px;
            height: 22px;
            border-radius: 6px;
            border: 2px solid #D1D5DB;
            flex-shrink: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all var(--transition-fast);
            background: #fff;
        }
        .checklist-item.checked .checklist-checkbox {
            background: #10B981;
            border-color: #10B981;
        }
        .checklist-checkbox i {
            width: 14px;
            height: 14px;
            color: #fff;
            opacity: 0;
            transform: scale(0.5);
            transition: all var(--transition-fast);
        }
        .checklist-item.checked .checklist-checkbox i {
            opacity: 1;
            transform: scale(1);
        }
        .checklist-highlight {
            display: none;
            margin-top: 12px;
            padding: 16px 20px;
            background: linear-gradient(135deg, #FFFDF5, #FFF8E1);
            border: 2px solid var(--yellow);
            border-radius: var(--radius);
            font-weight: 600;
            font-size: 15px;
            color: var(--navy);
            text-align: center;
            animation: fadeInUp 0.4s ease;
            box-shadow: var(--shadow-md);
        }
        .checklist-highlight.visible {
            display: block;
        }
        .checklist-counter {
            font-size: 12px;
            color: var(--text-tertiary);
            margin-top: 8px;
            text-align: right;
            font-weight: 500;
        }

        @keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(10px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* ============ OFFER CARDS ============ */
        .offer-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 12px;
        }
        .offer-card {
            background: var(--card-bg);
            border-radius: var(--radius-lg);
            padding: 20px 20px;
            border: 2px solid var(--border-light);
            text-align: center;
            transition: all var(--transition);
            position: relative;
            box-shadow: var(--shadow-sm);
        }
        .offer-card:hover {
            transform: translateY(-3px);
            box-shadow: var(--shadow-lg);
        }
        .offer-card.featured {
            border-color: var(--yellow);
            box-shadow: var(--shadow-md), 0 0 0 6px rgba(255, 190, 70, 0.08);
            background: linear-gradient(180deg, #FFFEFA 0%, #fff 30%);
        }
        .offer-badge {
            display: inline-block;
            padding: 6px 14px;
            border-radius: 20px;
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 10px;
        }
        .offer-badge.special {
            background: #FFF3D6;
            color: #B45309;
        }
        .offer-badge.official {
            background: #E5E7EB;
            color: #4B5563;
        }
        .offer-card h3 {
            font-size: 17px;
            font-weight: 700;
            color: var(--navy);
            margin-bottom: 12px;
            letter-spacing: -0.3px;
        }
        .offer-price-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 8px 0;
            border-bottom: 1px solid var(--border-light);
            font-size: 13px;
            color: var(--text-secondary);
        }
        .offer-price-row:last-child {
            border-bottom: none;
        }
        .offer-price-row .label {
            font-weight: 500;
        }
        .offer-price-row .value {
            font-weight: 700;
            color: var(--navy);
            font-size: 15px;
        }
        .offer-price-row .value.big {
            font-size: 20px;
            color: var(--navy);
        }

        /* ============ SCRIPT BOX ============ */
        .script-box {
            background: #FAFBFC;
            border: 1px solid #E5E7EB;
            border-radius: var(--radius-lg);
            padding: 20px 24px;
            font-size: 14px;
            line-height: 1.8;
            color: var(--text);
            position: relative;
            white-space: pre-line;
            font-style: italic;
        }
        .btn-copy {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            margin-top: 12px;
            padding: 10px 20px;
            background: var(--navy);
            color: #fff;
            border: none;
            border-radius: 25px;
            cursor: pointer;
            font-weight: 600;
            font-size: 13.5px;
            letter-spacing: 0.2px;
            transition: all var(--transition-fast);
            font-family: inherit;
        }
        .btn-copy:hover {
            background: var(--navy-light);
            box-shadow: var(--shadow-md);
            transform: translateY(-1px);
        }
        .btn-copy:active {
            transform: scale(0.97);
        }
        .btn-copy.copied {
            background: #059669;
        }
        .btn-copy i {
            width: 16px;
            height: 16px;
        }

        /* ============ OBJECTIONS ACCORDION ============ */
        .accordion-list {
            display: flex;
            flex-direction: column;
            gap: 8px;
        }
        .accordion-item {
            background: var(--card-bg);
            border-radius: var(--radius);
            border: 1px solid var(--border-light);
            overflow: hidden;
            transition: all var(--transition);
            box-shadow: var(--shadow-xs);
        }
        .accordion-item.open {
            border-color: var(--yellow);
            box-shadow: var(--shadow-md);
        }
        .accordion-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 16px 20px;
            cursor: pointer;
            font-weight: 600;
            font-size: 14.5px;
            color: var(--navy);
            user-select: none;
            -webkit-tap-highlight-color: transparent;
            transition: background var(--transition-fast);
            gap: 12px;
        }
        .accordion-header:hover {
            background: #FAFBFC;
        }
        .accordion-header i.chevron {
            width: 20px;
            height: 20px;
            flex-shrink: 0;
            transition: transform var(--transition);
            color: var(--text-tertiary);
        }
        .accordion-item.open .accordion-header i.chevron {
            transform: rotate(180deg);
            color: var(--yellow);
        }
        .accordion-body {
            max-height: 0;
            overflow: hidden;
            transition: max-height var(--transition-slow), padding var(--transition-slow);
            padding: 0 20px;
            font-size: 14px;
            color: var(--text-secondary);
            line-height: 1.7;
            background: #FAFBFC;
            border-top: 1px solid transparent;
        }
        .accordion-item.open .accordion-body {
            max-height: 300px;
            padding: 16px 20px;
            border-top-color: #F3F4F6;
        }

        /* ============ COMMISSION HIGHLIGHT ============ */
        .commission-highlight {
            background: linear-gradient(135deg, #FFFDF5 0%, #FFFBEB 100%);
            border: 2px solid var(--yellow);
            border-radius: var(--radius-lg);
            padding: 20px 24px;
            text-align: center;
            margin-bottom: 14px;
            box-shadow: var(--shadow-md);
        }
        .commission-highlight .big-percent {
            font-size: 48px;
            font-weight: 900;
            color: var(--navy);
            letter-spacing: -2px;
            line-height: 1;
        }
        .commission-examples {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 10px;
        }
        .commission-example-card {
            background: var(--card-bg);
            border-radius: var(--radius);
            padding: 16px;
            text-align: center;
            border: 1px solid var(--border-light);
            box-shadow: var(--shadow-xs);
            transition: all var(--transition);
        }
        .commission-example-card:hover {
            box-shadow: var(--shadow-md);
            transform: translateY(-2px);
        }
        .commission-example-card .implant {
            font-size: 12px;
            color: var(--text-secondary);
            font-weight: 500;
        }
        .commission-example-card .implant-val {
            font-size: 24px;
            font-weight: 800;
            color: var(--navy);
            letter-spacing: -0.5px;
        }
        .commission-example-card .arrow-down {
            font-size: 18px;
            color: var(--yellow);
            margin: 4px 0;
        }
        .commission-example-card .commission-val {
            font-size: 26px;
            font-weight: 900;
            color: #059669;
            letter-spacing: -0.5px;
        }

        /* ============ TIMELINE ============ */
        .timeline {
            display: flex;
            flex-direction: column;
            gap: 0;
            position: relative;
            padding-left: 36px;
        }
        .timeline::before {
            content: '';
            position: absolute;
            left: 18px;
            top: 8px;
            bottom: 8px;
            width: 2px;
            background: #E5E7EB;
            border-radius: 1px;
        }
        .timeline-step {
            position: relative;
            padding: 10px 0 10px 20px;
            font-size: 14px;
            font-weight: 500;
            color: var(--text);
            display: flex;
            align-items: center;
            gap: 8px;
            transition: all var(--transition-fast);
        }
        .timeline-step::before {
            content: '';
            position: absolute;
            left: -22px;
            top: 50%;
            transform: translateY(-50%);
            width: 10px;
            height: 10px;
            border-radius: 50%;
            background: #fff;
            border: 2.5px solid var(--navy);
            z-index: 2;
            transition: all var(--transition-fast);
        }
        .timeline-step:hover::before {
            background: var(--yellow);
            border-color: var(--yellow);
            box-shadow: 0 0 0 6px rgba(255, 190, 70, 0.2);
        }
        .timeline-step .step-num {
            width: 26px;
            height: 26px;
            border-radius: 50%;
            background: var(--navy);
            color: #fff;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 11px;
            font-weight: 700;
            flex-shrink: 0;
        }

        /* ============ META CARD ============ */
        .meta-card {
            background: linear-gradient(135deg, var(--navy) 0%, #003d61 100%);
            color: #fff;
            border-radius: var(--radius-lg);
            padding: 24px 28px;
            box-shadow: var(--shadow-lg);
        }
        .meta-card h3 {
            font-size: 16px;
            font-weight: 600;
            opacity: 0.9;
            margin-bottom: 14px;
            letter-spacing: -0.2px;
        }
        .meta-stats {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 12px;
            text-align: center;
        }
        .meta-stat .stat-num {
            font-size: 32px;
            font-weight: 900;
            letter-spacing: -1px;
            color: var(--yellow);
            line-height: 1;
        }
        .meta-stat .stat-label {
            font-size: 11px;
            opacity: 0.75;
            margin-top: 4px;
            font-weight: 500;
            letter-spacing: 0.2px;
            text-transform: uppercase;
        }

        /* ============ MINDSET ============ */
        .mindset-list {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 8px;
        }
        .mindset-item {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 14px 16px;
            background: var(--card-bg);
            border-radius: var(--radius);
            border: 1px solid var(--border-light);
            font-size: 14px;
            font-weight: 500;
            color: var(--navy);
            transition: all var(--transition-fast);
            box-shadow: var(--shadow-xs);
        }
        .mindset-item:hover {
            border-color: var(--yellow);
            box-shadow: var(--shadow-md);
            transform: translateX(3px);
        }
        .mindset-item i {
            width: 20px;
            height: 20px;
            color: var(--yellow);
            flex-shrink: 0;
        }

        /* ============ QUOTE CARDS ============ */
        .quote-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 12px;
        }
        .quote-card {
            background: var(--card-bg);
            border-radius: var(--radius-lg);
            padding: 20px 22px;
            border: 1px solid var(--border-light);
            font-size: 15px;
            font-weight: 600;
            color: var(--navy);
            text-align: center;
            letter-spacing: -0.2px;
            transition: all var(--transition);
            box-shadow: var(--shadow-xs);
            position: relative;
        }
        .quote-card:hover {
            box-shadow: var(--shadow-lg);
            transform: translateY(-2px);
            border-color: var(--yellow);
        }
        .quote-card i {
            display: block;
            margin: 0 auto 8px;
            color: var(--yellow);
            width: 28px;
            height: 28px;
            opacity: 0.7;
        }

        /* ============ FINAL MESSAGE CARD ============ */
        .final-message-card {
            background: linear-gradient(135deg, var(--navy) 0%, #003d61 100%);
            color: #fff;
            border-radius: var(--radius-xl);
            padding: 40px 32px;
            text-align: center;
            box-shadow: var(--shadow-xl);
            border: 2px solid var(--yellow);
            position: relative;
            overflow: hidden;
        }
        .final-message-card::before {
            content: '';
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: radial-gradient(circle, rgba(255, 190, 70, 0.08) 0%, transparent 60%);
            pointer-events: none;
        }
        .final-message-card h2 {
            color: #fff;
            font-size: 24px;
            margin-bottom: 16px;
        }
        .final-message-card .highlight-phrase {
            font-size: 18px;
            font-weight: 700;
            color: var(--yellow);
            margin-top: 20px;
            padding: 16px;
            background: rgba(255, 255, 255, 0.05);
            border-radius: var(--radius);
            border: 1px dashed rgba(255, 190, 70, 0.4);
        }

        /* ============ FOOTER ============ */
        .page-footer {
            background: #060b16;
            color: #7f8ba1;
            padding: 50px 0 30px;
            border-top: 1px solid rgba(255, 255, 255, 0.04);
            margin-top: 40px;
            width: 100%;
        }
        .footer-inner {
            max-width: 1100px;
            margin: 0 auto;
            padding: 0 32px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 30px;
            margin-bottom: 34px;
        }
        .footer-logo {
            display: flex;
            align-items: center;
            gap: 14px;
        }
        .footer-logo-icon {
            width: 52px;
            height: 52px;
            flex-shrink: 0;
        }
        .footer-logo-icon img {
            width: 100%;
            height: 100%;
            object-fit: contain;
        }
        .footer-logo-text {
            font-weight: 700;
            color: #fff;
            font-size: 1rem;
            letter-spacing: 0.2em;
        }
        .footer-links {
            display: flex;
            gap: 26px;
            color: #c8d3e3;
        }
        .footer-links a {
            color: #c8d3e3;
            text-decoration: none;
            font-size: 0.9rem;
            transition: color 0.2s ease;
        }
        .footer-links a:hover {
            color: var(--yellow);
        }
        .footer-bottom {
            text-align: center;
            color: #7f8ba1;
            font-size: 0.92rem;
            border-top: 1px solid rgba(255, 255, 255, 0.05);
            padding-top: 24px;
            max-width: 1100px;
            margin: 0 auto;
            padding-left: 32px;
            padding-right: 32px;
        }

        /* ============ TOAST ============ */
        .toast {
            position: fixed;
            bottom: 100px;
            left: 50%;
            transform: translateX(-50%) translateY(100px);
            background: #1F2937;
            color: #fff;
            padding: 12px 24px;
            border-radius: 30px;
            font-weight: 600;
            font-size: 13.5px;
            z-index: 200;
            opacity: 0;
            transition: all var(--transition);
            pointer-events: none;
            letter-spacing: -0.1px;
            box-shadow: var(--shadow-xl);
        }
        .toast.show {
            opacity: 1;
            transform: translateX(-50%) translateY(0);
        }

        /* ============ KIT DE VENDAS ============ */
        .kit-pitch-card {
            background: linear-gradient(135deg, #FFFDF5, #FFFBEB);
            border: 2px solid var(--yellow);
            border-radius: var(--radius-lg);
            padding: 24px 28px;
            margin-bottom: 20px;
            box-shadow: var(--shadow-md);
        }
        .kit-rules-card {
            background: #FFF5F5;
            border: 1px solid #FECACA;
            border-radius: var(--radius-lg);
            padding: 20px 24px;
            margin-bottom: 20px;
        }
        .data-checklist {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 12px;
            margin-bottom: 16px;
        }
        .data-checklist .data-group {
            background: var(--card-bg);
            border-radius: var(--radius);
            padding: 16px;
            border: 1px solid var(--border-light);
        }
        .data-group h4 {
            font-size: 14px;
            font-weight: 700;
            color: var(--navy);
            margin-bottom: 8px;
            display: flex;
            align-items: center;
            gap: 6px;
        }

        /* ============ RESPONSIVE ============ */
        @media (max-width: 1024px) {
            .sidebar {
                transform: translateX(-100%);
            }
            .sidebar.open {
                transform: translateX(0);
            }
            .sidebar-overlay {
                display: block;
            }
            .main-content {
                margin-left: 0;
                padding: 20px 16px 40px;
            }
            .menu-toggle {
                display: flex;
            }
            .hero-title {
                font-size: 26px;
            }
            .sell-grid,
            .scenario,
            .offer-grid,
            .commission-examples,
            .mindset-list,
            .quote-grid,
            .golden-rule-card ul,
            .data-checklist,
            .mvv-grid {
                grid-template-columns: 1fr;
            }
            .meta-stats {
                grid-template-columns: repeat(2, 1fr);
                gap: 16px;
            }
            .two-col-grid {
                grid-template-columns: 1fr;
                gap: 32px;
            }
            .footer-inner {
                flex-direction: column;
                align-items: flex-start;
                padding: 0 16px;
            }
            .footer-links {
                flex-wrap: wrap;
                gap: 16px;
            }
            .footer-bottom {
                padding-left: 16px;
                padding-right: 16px;
            }
        }

        @media (max-width: 640px) {
            .hero-title {
                font-size: 22px;
            }
            .benefits-grid {
                grid-template-columns: 1fr;
            }
            .meta-stat .stat-num {
                font-size: 24px;
            }
            .commission-highlight .big-percent {
                font-size: 36px;
            }
            .btn-copy {
                width: 100%;
                justify-content: center;
            }
            .final-message-card {
                padding: 28px 18px;
            }
            .final-message-card h2 {
                font-size: 20px;
            }
        }
