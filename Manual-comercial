    <script>
        document.addEventListener('DOMContentLoaded', () => {
            lucide.createIcons();

            // Progress bar
            const progressBar = document.getElementById('progressBar');
            window.addEventListener('scroll', () => {
                const scrollTop = window.scrollY;
                const docHeight = document.documentElement.scrollHeight - window.innerHeight;
                const progress = docHeight > 0 ? Math.min((scrollTop / docHeight) * 100, 100) : 0;
                progressBar.style.width = progress + '%';
            });

            // Header scroll effect
            const header = document.getElementById('appHeader');
            window.addEventListener('scroll', () => {
                header.classList.toggle('scrolled', window.scrollY > 20);
            });

            // Scroll Reveal
            const revealElements = document.querySelectorAll('.reveal');
            const revealObserver = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        entry.target.classList.add('visible');
                        revealObserver.unobserve(entry.target);
                    }
                });
            }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });
            revealElements.forEach(el => revealObserver.observe(el));

            // Accordion
            const accordionData = [
                { title: '💰 Está caro',
                    body: '<strong>Resposta:</strong> Quanto vale perder apenas um cliente por semana?<br>Na maioria dos negócios esse valor já paga o investimento.' },
                { title: '🤔 Vou pensar',
                    body: '<strong>Resposta:</strong> Sem problemas.<br>Posso deixar uma condição de lançamento reservada por alguns dias.' },
                { title: '👩‍💼 Já tenho secretária',
                    body: '<strong>Resposta:</strong> Perfeito.<br>A ideia não é substituir ninguém.<br>É justamente ajudar sua equipe respondendo imediatamente quando ela não consegue.' },
                { title: '🚫 Não preciso',
                    body: '<strong>Resposta:</strong> Tudo certo.<br>Posso apenas fazer uma pergunta?<br>Hoje vocês respondem todas as mensagens imediatamente, inclusive à noite e nos finais de semana?' }
            ];
            const accordionList = document.getElementById('accordionList');
            accordionData.forEach(item => {
                const div = document.createElement('div');
                div.className = 'accordion-item';
                div.innerHTML =
                    `<div class="accordion-header">${item.title} <i data-lucide="chevron-down" class="chevron"></i></div><div class="accordion-body">${item.body}</div>`;
                accordionList.appendChild(div);
            });
            lucide.createIcons();
            document.querySelectorAll('.accordion-header').forEach(header => {
                header.addEventListener('click', () => {
                    const item = header.parentElement;
                    document.querySelectorAll('.accordion-item.open').forEach(i => { if (i !== item) i
                            .classList.remove('open'); });
                    item.classList.toggle('open');
                });
            });

            // Checklist
            const checklistItems = document.querySelectorAll('.checklist-item');
            const checklistHighlight = document.getElementById('checklistHighlight');
            const checklistCounter = document.getElementById('checklistCounter');

            function updateChecklist() {
                const count = document.querySelectorAll('.checklist-item.checked').length;
                checklistCounter.textContent = `${count} de 8 itens marcados`;
                checklistHighlight.classList.toggle('visible', count >= 3);
            }
            checklistItems.forEach(item => {
                item.addEventListener('click', () => {
                    item.classList.toggle('checked');
                    updateChecklist();
                    item.style.transform = 'scale(0.98)';
                    setTimeout(() => item.style.transform = '', 150);
                });
            });
            updateChecklist();

            // Copy function
            function copyToClipboard(text, button, originalHTML) {
                navigator.clipboard.writeText(text).then(() => {
                    button.classList.add('copied');
                    button.innerHTML = '<i data-lucide="check"></i> Copiado!';
                    lucide.createIcons();
                    showToast('✅ Texto copiado!');
                    setTimeout(() => {
                        button.classList.remove('copied');
                        button.innerHTML = originalHTML;
                        lucide.createIcons();
                    }, 2000);
                }).catch(() => showToast('⚠️ Erro ao copiar.'));
            }

            const btnCopyScript = document.getElementById('btnCopyScript');
            const scriptText = document.getElementById('scriptText');
            btnCopyScript.addEventListener('click', () => copyToClipboard(scriptText.innerText.trim(),
                btnCopyScript, '<i data-lucide="copy"></i> Copiar mensagem'));

            const btnCopyExplicacao = document.getElementById('btnCopyExplicacao');
            const explicacaoPluri = document.getElementById('explicacaoPluri');
            btnCopyExplicacao.addEventListener('click', () => copyToClipboard(explicacaoPluri.innerText.trim(),
                btnCopyExplicacao, '<i data-lucide="copy"></i> Copiar explicação'));

            const btnCopyPitch = document.getElementById('btnCopyPitch');
            const pitchText = document.getElementById('pitchText');
            btnCopyPitch.addEventListener('click', () => copyToClipboard(pitchText.innerText.trim(), btnCopyPitch,
                '<i data-lucide="copy"></i> Copiar Pitch'));

            const btnCopyDiferencial = document.getElementById('btnCopyDiferencial');
            const diferencialText = document.getElementById('diferencialText');
            btnCopyDiferencial.addEventListener('click', () => copyToClipboard(diferencialText.innerText.trim(),
                btnCopyDiferencial, '<i data-lucide="copy"></i> Copiar diferencial'));

            function showToast(msg) {
                const toast = document.getElementById('toast');
                toast.textContent = msg;
                toast.classList.add('show');
                clearTimeout(window.toastTimeout);
                window.toastTimeout = setTimeout(() => toast.classList.remove('show'), 2200);
            }

            // Sidebar mobile
            const sidebar = document.getElementById('sidebar');
            const overlay = document.getElementById('sidebarOverlay');
            const toggle = document.getElementById('menuToggle');

            function closeSidebar() { sidebar.classList.remove('open');
                overlay.classList.remove('active');
                document.body.style.overflow = ''; }

            function openSidebar() { sidebar.classList.add('open');
                overlay.classList.add('active');
                document.body.style.overflow = 'hidden'; }
            toggle.addEventListener('click', () => sidebar.classList.contains('open') ? closeSidebar() :
                openSidebar());
            overlay.addEventListener('click', closeSidebar);
            document.querySelectorAll('.sidebar-nav a').forEach(link => link.addEventListener('click', () => window
                .innerWidth <= 1024 && setTimeout(closeSidebar, 150)));
            document.addEventListener('keydown', e => { if (e.key === 'Escape' && sidebar.classList.contains('open'))
                    closeSidebar(); });

            // Scroll spy
            const sections = document.querySelectorAll('.section[id]');
            const links = document.querySelectorAll('.sidebar-nav a');
            window.addEventListener('scroll', () => {
                let current = '';
                sections.forEach(s => { if (window.scrollY >= s.offsetTop - 200) current = s.getAttribute(
                        'id'); });
                links.forEach(l => l.classList.toggle('active', l.getAttribute('data-section') === current));
            });

            window.addEventListener('resize', () => { if (window.innerWidth > 1024) closeSidebar();
                lucide.createIcons(); });
            setTimeout(() => lucide.createIcons(), 100);
        });
    </script>
